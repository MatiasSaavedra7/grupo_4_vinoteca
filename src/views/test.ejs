<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pagina de pruebas</title>
</head>
<style>
    .pages {
        display: flex;
        justify-content: center;
        gap: 10px;
    }
    .pages a {
        color: inherit;
        text-decoration: none;
        background-color: grey;
        padding: 5px;
        border-radius: 10px;
    }
</style>

<body>
    <a href="/">
        <h3>HOME</h3>
    </a>
    <h1>Productos!!!!</h1>
    <h2>Cantidad de Productos: <%= count %></h2>
    <h3>Cantidad de Páginas: <%= totalPages %></h3>
    <ul>
        <% products.forEach(product => { %>
            <li>
                <h5>
                    <%= product.name %> - ID: <%= product.id %>
                </h5>
                <img src="/images/products/<%= product.image %>" width="80px">
                <p>$<%= product.price %></p>
                <% if (product.country) { %>
                    <p>Origen: <%= product.country.name %></p>
                <% } %>
            </li>
            <% }) %>
    </ul>
    <div class="pages">
        <% for( let i = 0; i < totalPages; i++ ) { %>
            <a href="/test/<%= i %>"><%= i %></a>
        <% } %>
    </div>

</body>

</html>